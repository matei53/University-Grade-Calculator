[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .venv,
    venv,
    env,
    .mypy_cache,
    htmlcov,
    dist,
    build,
    *.egg-info,
    server/migrations

ignore =
    # E501: line too long (black handles this)
    E501,
    # W503: line break before binary operator
    W503,
    # E203: whitespace before ':'
    E203

per-file-ignores =
    __init__.py: F401,F403
    tests/*.py: F811,E402
    conftest.py: F401,E402
    main.py: E402
    server/main.py: E402
    server/seed.py: E402
