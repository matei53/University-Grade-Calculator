# Copy this file to .env and fill in your values.

# --- Local development (running the server directly, not via Docker) ---
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/unigrades_db
SECRET_KEY=your-secret-key-change-this

# --- Docker Compose ---
# These are used by docker-compose.yml to initialise the postgres container
# and build the server's DATABASE_URL. On a fresh machine the postgres volume
# will be created with exactly these credentials, so they just need to be
# consistent with each other.
POSTGRES_USER=gradeapp
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=gradeapp
